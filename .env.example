# Public site URL (used for metadata, OG tags, and canonical links)
# Set to your production domain after connecting it in Vercel.
NEXT_PUBLIC_APP_URL=https://fuelthedons.com

# Supabase PostgreSQL (required for production DB mode)
# Transaction pooler (port 6543) — use for DATABASE_URL on Vercel serverless
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session/Direct (port 5432) — use for DIRECT_URL (Prisma migrations, db push, seed)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Future: Clerk authentication
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# Single school (Madonna High School only at launch)
SCHOOL_SLUG=madonna-high-school
# Optional override when multiple schools exist in DB
# SCHOOL_ID=

# Stripe payments (parent prepay / add funds)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Parent portal — external family login links (optional overrides)
# NEXT_PUBLIC_FACTS_FAMILY_PORTAL_URL=https://www.factsmgt.com/
# NEXT_PUBLIC_ASSETPILOT_EDU_URL=https://assetpilotedu.com
# NEXT_PUBLIC_SCHOOL_NUTRITION_EMAIL=nutrition@madonnahs.org

# Outbound email (Resend) — required for welcome, agreement, deposit, and broadcast emails
RESEND_API_KEY=
# Must use a verified domain in Resend (e.g. fuelthedons.com)
EMAIL_FROM="Fuel The Dons <noreply@fuelthedons.com>"
# Set to false to store notifications without sending (default: true)
# EMAIL_ENABLED=true

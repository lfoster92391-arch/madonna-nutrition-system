generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  logoUrl        String?
  primaryColor   String   @default("#001E62")
  secondaryColor String   @default("#C8CDD7")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users            User[]
  students         Student[]
  transactions     Transaction[]
  inventory        InventoryItem[]
  storageLocations StorageLocation[]
  inventoryMovements InventoryMovement[]
  receivingRecords ReceivingRecord[]
  receiptScans     ReceiptScan[]
  productionOrders ProductionOrder[]
  notifications    Notification[]
  menus            Menu[]
  forms            Form[]
  logs             AuditLog[]
  calendarEvents   CalendarEvent[]
  calendarSettings CalendarSettings?
  mealTemplates            MealTemplate[]
  teacherLunchReservations TeacherLunchReservation[]
  studentLunchSignups      StudentLunchSignup[]
  lunchAgreements          LunchAgreement[]
  lunchReservations        LunchReservation[]
  onboardingPricing        OnboardingPricing?
  agreementVersions        AgreementVersion[]
  agreementSignatures      AgreementSignature[]
  agreementAuditLogs       AgreementAuditLog[]
  announcements            Announcement[]
}

model User {
  id               String     @id @default(cuid())
  clerkId          String?    @unique
  username         String     @unique
  email            String     @unique
  firstName        String
  lastName         String
  phone            String?
  badgeId          String?
  role             UserRole   @default(STAFF)
  status           UserStatus @default(ACTIVE)
  passwordHash        String?
  mustChangePassword  Boolean    @default(false)
  linkedStudentIds String[]   @default([])
  department       String?
  accountBalance   Decimal    @default(0) @db.Decimal(10, 2)
  lastLoginAt      DateTime?
  schoolId         String
  school           School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  processedTransactions  Transaction[]            @relation("ProcessedByUser")
  teacherReservations  TeacherLunchReservation[]
  assistedSignups      StudentLunchSignup[]       @relation("SignedUpByTeacher")
  inboxNotifications   Notification[]           @relation("UserNotifications")

  @@unique([schoolId, badgeId])
}

enum UserRole {
  ADMIN
  STAFF
  CASHIER
  PARENT
  TEACHER
  EXECUTIVE
}

enum UserStatus {
  ACTIVE
  DISABLED
}

model Student {
  id                  String   @id @default(cuid())
  externalId          String
  firstName           String
  lastName            String
  photo               String?
  grade               String
  homeroom            String?
  balance             Decimal  @default(0) @db.Decimal(10, 2)
  dietaryRestrictions String[] @default([])
  disabled            Boolean  @default(false)
  schoolId            String
  school              School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  allergies          Allergy[]
  parentLinks        ParentStudent[]
  transactions       Transaction[]
  notifications      Notification[]
  profile            StudentProfile?
  allergySubmissions AllergySubmission[]
  medicalDocuments   MedicalDocument[]
  lunchSignups       StudentLunchSignup[]
  lunchAgreements    LunchAgreement[]
  lunchReservations  LunchReservation[]

  @@unique([schoolId, externalId])
}

model Allergy {
  id        String          @id @default(cuid())
  name      String
  severity  AllergySeverity @default(MODERATE)
  studentId String
  student   Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

enum AllergySeverity {
  SEVERE
  MODERATE
  INFORMATIONAL
}

model StudentProfile {
  id                       String    @id @default(cuid())
  studentId                String    @unique
  student                  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  dietaryRestrictions      Json      @default("[]")
  allergyVerified          Boolean   @default(false)
  allergyReviewedAt        DateTime?
  allergyExpiresAt         DateTime?
  updateRequestedAt        DateTime?
  medicalNotes             String?
  emergencyFoodContactName String?
  emergencyFoodContactPhone String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

enum AllergySubmissionStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  CLARIFICATION_REQUESTED
}

model AllergySubmission {
  id            String                  @id @default(cuid())
  studentId     String
  student       Student                 @relation(fields: [studentId], references: [id], onDelete: Cascade)
  submittedBy   String
  changePayload Json
  status        AllergySubmissionStatus @default(PENDING_REVIEW)
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewNote    String?
  createdAt     DateTime                @default(now())
}

model MedicalDocument {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  documentUrl String
  fileName    String
  version     Int
  uploadedAt  DateTime  @default(now())
  expiresAt   DateTime?
  uploadedBy  String
}

model Parent {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students ParentStudent[]
  lunchAgreements LunchAgreement[]
  agreementSignatures AgreementSignature[]
}

model ParentStudent {
  id           String @id @default(cuid())
  parentId     String
  studentId    String
  relationship String @default("Guardian")
  parent       Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
}

enum TransactionType {
  MEAL
  DEPOSIT
}

model Transaction {
  id                 String          @id @default(cuid())
  studentId          String
  student            Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolId           String
  school             School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  processedByUserId  String?
  processedBy        User?           @relation("ProcessedByUser", fields: [processedByUserId], references: [id], onDelete: SetNull)
  type               TransactionType @default(MEAL)
  mealType           String
  amount             Decimal         @db.Decimal(10, 2)
  balanceAfter       Decimal         @db.Decimal(10, 2)
  stripeSessionId    String?         @unique
  clientTransactionId String?        @unique
  createdAt          DateTime        @default(now())
}

model StorageLocation {
  id        String   @id @default(cuid())
  name      String
  zone      String
  capacity  Int?
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  items     InventoryItem[]
  movements InventoryMovement[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryItem {
  id                String           @id @default(cuid())
  name              String
  qty               Int
  unit              String
  cost              Decimal          @db.Decimal(10, 2)
  expiration        DateTime
  category          String
  lowStockThreshold Int              @default(10)
  barcode           String?
  sku               String?
  vendor            String?
  storageLocationId String?
  storageLocation   StorageLocation? @relation(fields: [storageLocationId], references: [id], onDelete: SetNull)
  lastReceivedAt    DateTime?
  schoolId          String
  school            School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  movements         InventoryMovement[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model InventoryMovement {
  id                String           @id @default(cuid())
  type              String
  quantity          Int
  note              String?
  inventoryItemId   String
  inventoryItem     InventoryItem    @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  storageLocationId String?
  storageLocation   StorageLocation? @relation(fields: [storageLocationId], references: [id], onDelete: SetNull)
  receivingRecordId String?
  receivingRecord   ReceivingRecord? @relation(fields: [receivingRecordId], references: [id], onDelete: SetNull)
  productionOrderId String?
  productionOrder   ProductionOrder? @relation(fields: [productionOrderId], references: [id], onDelete: SetNull)
  schoolId          String
  school            School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy         String?
  createdAt         DateTime         @default(now())
}

model ReceivingRecord {
  id            String              @id @default(cuid())
  vendorName    String
  invoiceNumber String?
  status        String              @default("draft")
  notes         String?
  lines         Json
  receivedAt    DateTime?
  approvedAt    DateTime?
  approvedBy    String?
  schoolId      String
  school        School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  movements     InventoryMovement[]
  receiptScans  ReceiptScan[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model ReceiptScan {
  id                 String           @id @default(cuid())
  fileName           String
  imageUrl           String?
  vendorGuess        String?
  ocrText            String?
  status             String           @default("pending")
  matchedReceivingId String?
  matchedReceiving   ReceivingRecord? @relation(fields: [matchedReceivingId], references: [id], onDelete: SetNull)
  schoolId           String
  school             School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())
}

model ProductionOrder {
  id              String              @id @default(cuid())
  title           String
  status          String              @default("planned")
  scheduledFor    DateTime
  portionsPlanned Int
  portionsMade    Int                 @default(0)
  mealTemplateId  String?
  mealTemplate    MealTemplate?       @relation(fields: [mealTemplateId], references: [id], onDelete: SetNull)
  notes           String?
  wasteLog        Json?
  schoolId        String
  school          School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  movements       InventoryMovement[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String?
  message   String
  channel   NotifyChannel    @default(EMAIL)
  read      Boolean          @default(false)
  emailSent Boolean          @default(false)
  studentId String?
  student   Student?         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?            @relation("UserNotifications", fields: [userId], references: [id], onDelete: SetNull)
  metadata  Json?
  schoolId  String
  school    School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
}

model Announcement {
  id          String               @id @default(cuid())
  title       String
  body        String               @db.Text
  audience    AnnouncementAudience @default(ALL)
  publishedBy String?
  schoolId    String
  school      School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

enum NotificationType {
  LOW_BALANCE
  NEGATIVE_BALANCE
  REPEATED_CHARGES
  MISSED_MEALS
  AGREEMENT_SIGNED
  DEPOSIT_SUCCESS
  EMAIL_OUTBOX
  ANNOUNCEMENT
}

enum AnnouncementAudience {
  PARENTS
  TEACHERS
  ALL
}

enum NotifyChannel {
  EMAIL
  SMS
}

model Menu {
  id        String   @id @default(cuid())
  name      String
  mealType  String
  allergens String[] @default([])
  calories  Int?
  date      DateTime
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Form {
  id        String   @id @default(cuid())
  title     String
  type      String
  content   Json
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model CalendarEvent {
  id             String        @id @default(cuid())
  title          String
  date           DateTime      @db.Date
  description    String?
  category       String
  color          String?
  mealTemplateId String?
  mealTemplate   MealTemplate? @relation(fields: [mealTemplateId], references: [id], onDelete: SetNull)
  publishStatus  String        @default("draft")
  publishedAt    DateTime?
  notes          String?
  schoolId       String
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model MealTemplate {
  id                String             @id @default(cuid())
  name              String
  description       String?
  category          String
  mealType          String
  allergens         String[]           @default([])
  ingredients       Json?
  nutritionNotes    String?
  portionNotes      String?
  gradeAvailability String[]           @default([])
  isReusable        Boolean            @default(true)
  isFavorite        Boolean            @default(false)
  isPublished       Boolean            @default(false)
  isArchived        Boolean            @default(false)
  lastUsedAt        DateTime?
  studentMealPrice  Decimal?           @db.Decimal(10, 2)
  alaCartePrice     Decimal?           @db.Decimal(10, 2)
  staffMealPrice    Decimal?           @db.Decimal(10, 2)
  schoolId          String
  school            School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  items             MealTemplateItem[]
  photos            MealPhoto[]
  calendarEvents    CalendarEvent[]
  productionOrders  ProductionOrder[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model MealTemplateItem {
  id             String       @id @default(cuid())
  name           String
  sortOrder      Int          @default(0)
  mealTemplateId String
  mealTemplate   MealTemplate @relation(fields: [mealTemplateId], references: [id], onDelete: Cascade)
}

model MealPhoto {
  id             String       @id @default(cuid())
  slot           String
  url            String
  mealTemplateId String
  mealTemplate   MealTemplate @relation(fields: [mealTemplateId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model CalendarSettings {
  id            String  @id @default(cuid())
  schoolId      String  @unique
  school        School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  headerTitle   String
  bannerMessage String?
  accentColor   String  @default("navy")
  schoolName    String
}

enum LunchPaymentMethod {
  ACCOUNT
  PREPAY_ONLINE
  PAY_AT_KIOSK
}

enum LunchReservationStatus {
  RESERVED
  CANCELLED
  PENDING
}

model TeacherLunchReservation {
  id             String                 @id @default(cuid())
  userId         String
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime               @db.Date
  mealName       String
  mealPrice      Decimal                @db.Decimal(10, 2)
  mealPhotoUrl   String?
  paymentMethod  LunchPaymentMethod
  status         LunchReservationStatus @default(RESERVED)
  pickupLocation String                 @default("Main Cafeteria")
  pickupStart    String                 @default("11:15 AM")
  pickupEnd      String                 @default("1:15 PM")
  schoolId       String
  school         School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([userId, date])
}

model StudentLunchSignup {
  id               String             @id @default(cuid())
  studentId        String
  student          Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date             DateTime           @db.Date
  mealName         String
  mealPrice        Decimal            @db.Decimal(10, 2)
  paymentMethod    LunchPaymentMethod
  signedUpByUserId String?
  signedUpBy       User?              @relation("SignedUpByTeacher", fields: [signedUpByUserId], references: [id], onDelete: SetNull)
  schoolId         String
  school           School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  signedUpAt       DateTime           @default(now())

  @@unique([studentId, date])
}

enum LunchAgreementStatus {
  PENDING
  SIGNED
  EXPIRED
  REVOKED
}

enum LunchReservationMealType {
  MAIN
  SIDE
  ALA_CARTE
  MILK
}

model LunchAgreement {
  id                   String               @id @default(cuid())
  parentId             String
  parent               Parent               @relation(fields: [parentId], references: [id], onDelete: Cascade)
  studentId            String
  student              Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  agreementVersionId   String?
  agreementVersion     AgreementVersion?    @relation(fields: [agreementVersionId], references: [id], onDelete: SetNull)
  agreementSignatureId String?
  agreementSignature   AgreementSignature?  @relation(fields: [agreementSignatureId], references: [id], onDelete: SetNull)
  signedAt             DateTime?
  signatureData        String?
  status               LunchAgreementStatus @default(PENDING)
  acceptedTerms        Boolean              @default(false)
  schoolId             String
  school               School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@unique([parentId, studentId])
}

enum AgreementVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AgreementSignatureStatus {
  PENDING
  SIGNED
  EXPIRED
  REVOKED
}

model AgreementVersion {
  id            String                 @id @default(cuid())
  versionLabel  String
  versionNumber Int
  status        AgreementVersionStatus   @default(DRAFT)
  effectiveDate DateTime
  expiresAt     DateTime?
  content       Json
  publishedAt   DateTime?
  publishedBy   String?
  schoolId      String
  school        School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  signatures    AgreementSignature[]
  auditLogs     AgreementAuditLog[]
  lunchAgreements LunchAgreement[]

  @@unique([schoolId, versionNumber])
}

model AgreementSignature {
  id                 String                   @id @default(cuid())
  agreementVersionId String
  agreementVersion   AgreementVersion         @relation(fields: [agreementVersionId], references: [id], onDelete: Cascade)
  parentId           String
  parent             Parent                   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  parentUserId       String?
  parentName         String
  relationship       String
  typedSignature     String
  studentIds         String[]
  signedAt           DateTime?
  ipAddress          String?
  status             AgreementSignatureStatus @default(PENDING)
  schoolId           String
  school             School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  auditLogs       AgreementAuditLog[]
  lunchAgreements LunchAgreement[]

  @@index([parentId, agreementVersionId])
  @@index([schoolId, status])
}

model AgreementAuditLog {
  id                 String              @id @default(cuid())
  action             String
  agreementVersionId String?
  agreementVersion   AgreementVersion?   @relation(fields: [agreementVersionId], references: [id], onDelete: SetNull)
  signatureId        String?
  signature          AgreementSignature? @relation(fields: [signatureId], references: [id], onDelete: SetNull)
  parentId           String?
  parentName         String?
  ipAddress          String?
  metadata           Json?
  performedBy        String?
  schoolId           String
  school             School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt          DateTime            @default(now())

  @@index([schoolId, createdAt])
}

model LunchReservation {
  id        String                   @id @default(cuid())
  studentId String
  student   Student                  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime                 @db.Date
  mealType  LunchReservationMealType
  price     Decimal                  @db.Decimal(10, 2)
  status    LunchReservationStatus   @default(RESERVED)
  schoolId  String
  school    School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  @@unique([studentId, date, mealType])
}

model OnboardingPricing {
  id                  String   @id @default(cuid())
  schoolId            String   @unique
  school              School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  mainMealPrice       Decimal  @default(3.00) @db.Decimal(10, 2)
  sideMealPrice       Decimal  @default(2.00) @db.Decimal(10, 2)
  alaCartePrice       Decimal  @default(4.50) @db.Decimal(10, 2)
  milkPrice           Decimal  @default(0.75) @db.Decimal(10, 2)
  agreementText       String   @db.Text
  emergencyPolicyText String   @db.Text
  updatedAt           DateTime @updatedAt
}

model AuditLog {
  id            String   @id @default(cuid())
  action        String
  entity        String
  entityType    String?
  entityId      String?
  metadata      Json?
  performedBy   String?
  performedAt   DateTime @default(now())
  previousValue Json?
  newValue      Json?
  reason        String?
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}
